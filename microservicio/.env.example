# Copiar como .env y ajustar valores. NUNCA commitear .env con datos reales.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=cambia_esta_contrasena_segura
POSTGRES_USER=epiadmin
POSTGRES_DB=epidiagnostix

# ── Anthropic / Claude API ─────────────────────────────────────────────────────
# Con esta key el extractor usa Claude (LLM real, sin reglas rígidas).
# Sin ella, cae automáticamente a extractor regex/spaCy (offline-first).
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Modelos ML ─────────────────────────────────────────────────────────────────
MODEL_DIR=/app/models
